import cv2
import numpy as np
import img2pdf
import os
import requests

def cam_scanner_cleanup(img_path):
    img = cv2.imread(img_path)
    gray = cv2.cvtColor(img, cv2.COLOR_BGR2GRAY)
    # Magic filter: removes shadows and whitens background
    cleaned = cv2.adaptiveThreshold(gray, 255, cv2.ADAPTIVE_THRESH_GAUSSIAN_C, 
                                    cv2.THRESH_BINARY, 11, 11)
    return cleaned

def run_automation():
    file_url = os.getenv("FILE_URL")
    sender = os.getenv("USER_NAME", "Ahmed")
    token = os.getenv("SLACK_BOT_TOKEN")

    # Create organized folder on the fly
    save_dir = f"Scans/{sender}"
    os.makedirs(save_dir, exist_ok=True)
    
    # Download image from Slack
    headers = {'Authorization': f'Bearer {token}'}
    r = requests.get(file_url, headers=headers)
    with open("temp.jpg", "wb") as f: f.write(r.content)

    # Process and save as PDF
    cleaned = cam_scanner_cleanup("temp.jpg")
    pdf_name = f"{save_dir}/Scan_{os.path.basename(file_url)}.pdf"
    success, buffer = cv2.imencode(".jpg", cleaned)
    with open(pdf_name, "wb") as f:
        f.write(img2pdf.convert(buffer.tobytes()))

if __name__ == "__main__":
    run_automation()
