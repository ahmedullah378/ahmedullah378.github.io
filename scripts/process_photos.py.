import cv2
import numpy as np
import img2pdf
import os
import requests

def cam_scanner_cleanup(img_bytes):
    nparr = np.frombuffer(img_bytes, np.uint8)
    img = cv2.imdecode(nparr, cv2.IMREAD_COLOR)
    gray = cv2.cvtColor(img, cv2.COLOR_BGR2GRAY)
    # Professional whitening filter
    cleaned = cv2.adaptiveThreshold(gray, 255, cv2.ADAPTIVE_THRESH_GAUSSIAN_C, 
                                    cv2.THRESH_BINARY, 11, 11)
    _, buffer = cv2.imencode(".jpg", cleaned)
    return buffer.tobytes()

def run_automation():
    urls = os.getenv("FILE_URL", "").split(",")
    token = os.getenv("SLACK_BOT_TOKEN")
    cleaned_images = []

    # 1. Create the Scans folder if it's missing
    if not os.path.exists("Scans"):
        os.makedirs("Scans")

    # 2. Process each image URL sent from your phone
    for url in urls:
        if not url: continue
        headers = {'Authorization': f'Bearer {token}'}
        r = requests.get(url, headers=headers)
        if r.status_code == 200:
            cleaned_images.append(cam_scanner_cleanup(r.content))

    # 3. Stitch them into ONE PDF
    if cleaned_images:
        pdf_path = "Scans/latest_document.pdf"
        with open(pdf_path, "wb") as f:
            f.write(img2pdf.convert(cleaned_images))
        print(f"Successfully created PDF with {len(cleaned_images)} pages.")

if __name__ == "__main__":
    run_automation()
